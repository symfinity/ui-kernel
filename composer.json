{
    "name": "symfinity/ui-kernel",
    "description": "Chameleon UI kernel — design tokens, flavours, and role CSS generation",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "symfony/config": "^6.4|^7.0",
        "symfony/dependency-injection": "^6.4|^7.0",
        "symfony/framework-bundle": "^6.4|^7.0",
        "symfony/http-kernel": "^6.4|^7.0",
        "symfony/twig-bundle": "^6.4|^7.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "symfony/yaml": "^6.4|^7.0"
    },
    "autoload": {
        "psr-4": {
            "Symfinity\\UiKernel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfinity\\UiKernel\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "version": "1.0.0-dev",
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "suggest": {
        "symfinity/ux-blocks-demo": "Integration demo hub — index and per-pack pages combining ui-kernel with ux-blocks"
    }
}
